# Copy to .env and fill in your provider details.
# Works with OpenAI, Groq, Together, Ollama, or any OpenAI-compatible endpoint.

LEMURA_API_KEY=your_api_key_here
LEMURA_BASE_URL=https://api.openai.com/v1
LEMURA_MODEL=gpt-4o-mini

# For a local Ollama instance, e.g.:
# LEMURA_API_KEY=ollama
# LEMURA_BASE_URL=http://localhost:11434/v1
# LEMURA_MODEL=llama3.1
