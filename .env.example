# Copy to .env and fill in your provider details.
# Works with OpenAI, Groq, Together, Ollama, or any OpenAI-compatible endpoint.

LEMURA_API_KEY=your_api_key_here
LEMURA_BASE_URL=https://api.openai.com/v1
LEMURA_MODEL=gpt-4o-mini

# Agent Configuration Options (Optional)
# LEMURA_MAX_TOKENS=100000              # Maximum total context window size in tokens
# LEMURA_MAX_ITERATIONS=8               # Maximum ReAct cycle iterations per turn
# LEMURA_MAX_STEPS=20                   # Maximum total tool calls per turn
# LEMURA_MAX_COMPLETION_TOKENS=4000     # Maximum tokens generated by LLM per request

# Advanced Agent Behaviors (Optional)
# LEMURA_ENABLE_GOAL_PLANNING=false       # Enable LLM decomposing requests into sub-goals
# LEMURA_ENABLE_GOAL_VERIFICATION=false   # Verify goals after execution and auto-correct
# LEMURA_ENABLE_CONTINUATION_PLANNING=false # Enable planning dynamic tool continuations
# LEMURA_PARALLEL_TOOL_CALLS=false       # Run independent tool calls in parallel (Promise.all)
# LEMURA_ENABLE_ROUTING=false            # Pre-classify chat vs task and route categories

# For a local Ollama instance, e.g.:
# LEMURA_API_KEY=ollama
# LEMURA_BASE_URL=http://localhost:11434/v1
# LEMURA_MODEL=llama3.1
